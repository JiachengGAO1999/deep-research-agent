# ============================================================
# LLM Configuration (OpenAI-compatible)
# ============================================================
# Supports any OpenAI-compatible API: DeepSeek, OpenAI, vLLM, etc.
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_API_KEY=your-api-key-here
LLM_MODEL_FAST=deepseek-chat
LLM_MODEL_STRONG=deepseek-reasoner

# Token limits
LLM_FAST_MAX_TOKENS=1024
LLM_STRONG_MAX_TOKENS=4096

# Thinking mode (deepseek-reasoner supports this; set false if model doesn't)
LLM_FAST_ENABLE_THINKING=false
LLM_STRONG_ENABLE_THINKING=true

# LLM timeout and retry
LLM_TIMEOUT=120
LLM_MAX_RETRIES=2

# Cost tracking (optional, per-1M-token prices)
LLM_INPUT_COST_PER_1M=0
LLM_OUTPUT_COST_PER_1M=0

# Report generation: strict (ValidatedClaims only) or llm (model-generated)
REPORT_GENERATION_MODE=strict

# ============================================================
# Tavily Search (required for Quick Research mode)
# ============================================================
# Get a free key at https://tavily.com
TAVILY_API_KEY=your-tavily-key-here
TAVILY_SEARCH_DEPTH=advanced
TAVILY_MAX_RESULTS_PER_QUERY=8
TAVILY_EXTRACT_DEPTH=advanced
TAVILY_MAX_SOURCES=20
TAVILY_TIMEOUT=30

# Quick Research mode limits
QUICK_MAX_SEARCH_ROUNDS=2
QUICK_MAX_QUERIES_PER_ROUND=6

# ============================================================
# Academic Data Sources (required for Strict mode)
# ============================================================
# OpenAlex (optional, improves rate limits)
OPENALEX_API_KEY=
OPENALEX_MAILTO=

# Semantic Scholar (optional)
SEMANTIC_SCHOLAR_API_KEY=

# ============================================================
# Database
# ============================================================
DATABASE_URL=sqlite+aiosqlite:///./storage/app.db

# ============================================================
# Search Limits
# ============================================================
MAX_SEARCH_ROUNDS=3
MAX_PAPERS_PER_SOURCE=20
MAX_SELECTED_PAPERS=20

# ============================================================
# Full text and evidence (Strict mode only)
# ============================================================
ENABLE_FULL_TEXT=false
EVIDENCE_BACKEND=abstract
PDF_PARSER_BACKEND=pymupdf

# ============================================================
# Server
# ============================================================
HOST=0.0.0.0
PORT=8000

# Mock mode: set to 1 to test without any API keys
# MOCK_MODE=1
