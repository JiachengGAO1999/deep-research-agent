# ============================================================
# LLM Configuration (OpenAI-compatible)
# ============================================================
# Real vLLM (requires SSH tunnel: ssh -L 18004:127.0.0.1:8004 sjtu-a800)
LLM_BASE_URL=http://127.0.0.1:18004/v1
LLM_API_KEY=EMPTY
LLM_MODEL_FAST=qwen3-8b-budget
LLM_MODEL_STRONG=qwen3-8b-budget

# Token limits (Qwen3-8B-budget max_model_len=8192)
LLM_FAST_MAX_TOKENS=1024
LLM_STRONG_MAX_TOKENS=4096

# Thinking mode (vLLM chat_template_kwargs)
# FAST: disable reasoning to reduce token waste
LLM_FAST_ENABLE_THINKING=false
# STRONG: enable reasoning for better analysis quality
LLM_STRONG_ENABLE_THINKING=true

# LLM timeout and retry
LLM_TIMEOUT=120
LLM_MAX_RETRIES=2
# Configure the selected hosted model's published prices for budget tracking.
LLM_INPUT_COST_PER_1M=0
LLM_OUTPUT_COST_PER_1M=0
REPORT_GENERATION_MODE=strict

# ============================================================
# Academic Data Sources
# ============================================================
# OpenAlex (optional, improves rate limits)
OPENALEX_API_KEY=
OPENALEX_MAILTO=

# Semantic Scholar (optional)
SEMANTIC_SCHOLAR_API_KEY=

# ============================================================
# Database
# ============================================================
DATABASE_URL=sqlite+aiosqlite:///./storage/app.db

# ============================================================
# Search Limits
# ============================================================
MAX_SEARCH_ROUNDS=3
MAX_PAPERS_PER_SOURCE=20
MAX_SELECTED_PAPERS=20

# ============================================================
# Full text and evidence
# ============================================================
# Keep disabled until a full-text backend is configured.
ENABLE_FULL_TEXT=false
# abstract | fts | paperqa
EVIDENCE_BACKEND=hybrid
DEFAULT_RETRIEVAL_PROFILE=quality
QUALITY_EVIDENCE_BACKEND=hybrid
HYBRID_DENSE_MODEL=BAAI/bge-m3
HYBRID_RERANK_MODEL=BAAI/bge-reranker-v2-m3
HYBRID_DEVICE=cpu
HYBRID_ENABLE_RERANKER=true
HYBRID_RRF_K=60
CANDIDATE_POOL_MULTIPLIER=5
# docling | pymupdf
PDF_PARSER_BACKEND=docling
PDF_CACHE_DIR=./storage/cache/pdf
PDF_CACHE_TTL_DAYS=7
PDF_MAX_SIZE_MB=50
PDF_DOWNLOAD_TIMEOUT=60
EVIDENCE_TOP_K=8
EVIDENCE_MAX_PER_PAPER=3
PAPERQA_INDEX_DIR=./storage/paperqa
PAPERQA_SETTINGS=high_quality
# PaperQA2 uses LiteLLM model identifiers. For a custom OpenAI-compatible
# endpoint this is commonly an openai/<model> identifier.
PAPERQA_LLM=
PAPERQA_SUMMARY_LLM=
PAPERQA_EMBEDDING=text-embedding-3-small

# ============================================================
# Server
# ============================================================
HOST=0.0.0.0
PORT=8000

# Mock mode: set to 1 to bypass LLM and use mock data
# MOCK_MODE=1
# Unpaywall (free OA resolver, requires email)
UNPAYWALL_EMAIL=
