# ============================================================
# LLM Configuration (OpenAI-compatible)
# ============================================================
# Real vLLM (requires SSH tunnel: ssh -L 18004:127.0.0.1:8004 sjtu-a800)
LLM_BASE_URL=http://127.0.0.1:18004/v1
LLM_API_KEY=EMPTY
LLM_MODEL_FAST=qwen3-8b-budget
LLM_MODEL_STRONG=qwen3-8b-budget

# Token limits (Qwen3-8B-budget max_model_len=8192)
LLM_FAST_MAX_TOKENS=1024
LLM_STRONG_MAX_TOKENS=4096

# Thinking mode (vLLM chat_template_kwargs)
# FAST: disable reasoning to reduce token waste
LLM_FAST_ENABLE_THINKING=false
# STRONG: enable reasoning for better analysis quality
LLM_STRONG_ENABLE_THINKING=true

# LLM timeout and retry
LLM_TIMEOUT=120
LLM_MAX_RETRIES=2

# ============================================================
# Academic Data Sources
# ============================================================
# OpenAlex (optional, improves rate limits)
OPENALEX_API_KEY=
OPENALEX_MAILTO=

# Semantic Scholar (optional)
SEMANTIC_SCHOLAR_API_KEY=

# ============================================================
# Database
# ============================================================
DATABASE_URL=sqlite+aiosqlite:///./storage/app.db

# ============================================================
# Search Limits
# ============================================================
MAX_SEARCH_ROUNDS=3
MAX_PAPERS_PER_SOURCE=20
MAX_SELECTED_PAPERS=20

# ============================================================
# Server
# ============================================================
HOST=0.0.0.0
PORT=8000

# Mock mode: set to 1 to bypass LLM and use mock data
# MOCK_MODE=1
